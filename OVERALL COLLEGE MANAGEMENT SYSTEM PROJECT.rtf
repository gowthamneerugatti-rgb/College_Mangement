\cf1\b Add Department\par
\cf0\b0 <!-- Add this inside <div class="main-content">, below the cards -->\par
<div class="card" style="margin-top: 40px;">\par
    <h2 style="margin-bottom: 20px; color: #2f3e46;">Add Department</h2>\par
    <form id="addDeptForm">\par
        <div style="margin-bottom: 15px;">\par
            <label for="deptName" style="display:block; margin-bottom:5px; color:#52796f;">Department Name</label>\par
            <input type="text" id="deptName" name="deptName" placeholder="Enter Department Name" \par
                   style="width:100%; padding:10px; border-radius:6px; border:1px solid #ccc;">\par
        </div>\par
        <div style="margin-bottom: 15px;">\par
            <label for="deptHead" style="display:block; margin-bottom:5px; color:#52796f;">Head of Department</label>\par
            <input type="text" id="deptHead" name="deptHead" placeholder="Enter HOD Name" \par
                   style="width:100%; padding:10px; border-radius:6px; border:1px solid #ccc;">\par
        </div>\par
        <div style="margin-bottom: 15px;">\par
            <label for="numStaff" style="display:block; margin-bottom:5px; color:#52796f;">Number of Staff</label>\par
            <input type="number" id="numStaff" name="numStaff" placeholder="Enter Number of Staff" \par
                   style="width:100%; padding:10px; border-radius:6px; border:1px solid #ccc;">\par
        </div>\par
        <button type="submit" class="btn">Add Department</button>\par
    </form>\par
</div>\par
\par
<!-- Optional JavaScript to handle form submission -->\par
<script>\par
document.getElementById('addDeptForm').addEventListener('submit', function(e) \{\par
    e.preventDefault();\par
    const deptName = document.getElementById('deptName').value;\par
    const deptHead = document.getElementById('deptHead').value;\par
    const numStaff = document.getElementById('numStaff').value;\par
\par
    if(deptName && deptHead && numStaff) \{\par
        alert(`Department Added:\\nName: $\{deptName\}\\nHOD: $\{deptHead\}\\nStaff: $\{numStaff\}`);\par
        // Reset form\par
        this.reset();\par
\par
        // TODO: Here you can send the data to backend (C++/PHP/SQL)\par
    \} else \{\par
        alert('Please fill all fields!');\par
    \}\par
\});\par
</script>\par
