\par
// View All Records\par
void viewExams() \{\par
    if(examList.empty()) \{\par
        cout << "No Exam Records Found!" << endl;\par
        return;\par
    \}\par
\par
    cout << "\\n------ EXAM RECORDS ------" << endl;\par
\par
    for(int i = 0; i < examList.size(); i++) \{\par
        cout << "ID: " << examList[i].studentId\par
             << " | Name: " << examList[i].studentName\par
             << " | S1: " << examList[i].subject1\par
             << " | S2: " << examList[i].subject2\par
             << " | S3: " << examList[i].subject3\par
             << endl;\par
    \}\par
\}\par
\par
// Search Result\par
void searchResult() \{\par
    int id;\par
    cout << "Enter Student ID to Search: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < examList.size(); i++) \{\par
        if(examList[i].studentId == id) \{\par
            cout << "Record Found!" << endl;\par
            cout << "Name: " << examList[i].studentName << endl;\par
            cout << "Marks: "\par
                 << examList[i].subject1 << ", "\par
                 << examList[i].subject2 << ", "\par
                 << examList[i].subject3 << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Update Marks\par
void updateMarks() \{\par
    int id;\par
    cout << "Enter Student ID to Update: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < examList.size(); i++) \{\par
        if(examList[i].studentId == id) \{\par
            cout << "Enter New Marks for Subject 1: ";\par
            cin >> examList[i].subject1;\par
\par
            cout << "Enter New Marks for Subject 2: ";\par
            cin >> examList[i].subject2;\par
\par
            cout << "Enter New Marks for Subject 3: ";\par
            cin >> examList[i].subject3;\par
\par
            cout << "Marks Updated Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Delete Record\par
void deleteRecord() \{\par
    int id;\par
    cout << "Enter Student ID to Delete Record: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < examList.size(); i++) \{\par
        if(examList[i].studentId == id) \{\par
            examList.erase(examList.begin() + i);\par
            cout << "Record Deleted Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Calculate Total, Average & Grade\par
void calculateResult() \{\par
    int id;\par
    cout << "Enter Student ID to Calculate Result: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < examList.size(); i++) \{\par
        if(examList[i].studentId == id) \{\par
\par
            int total = examList[i].subject1 + \par
                        examList[i].subject2 + \par
                        examList[i].subject3;\par
\par
            float average = total / 3.0;\par
\par
            char grade;\par
\par
            if(average >= 90) grade = 'A';\par
            else if(average >= 75) grade = 'B';\par
            else if(average >= 60) grade = 'C';\par
            else if(average >= 40) grade = 'D';\par
            else grade = 'F';\par
\par
            cout << "Total Marks: " << total << endl;\par
            cout << "Average: " << average << endl;\par
            cout << "Grade: " << grade << endl;\par
\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
