    cout << "Enter Student Name: ";\par
    cin >> h.studentName;\par
\par
    cout << "Enter Room Number: ";\par
    cin >> h.roomNumber;\par
\par
    cout << "Enter Block Name: ";\par
    cin >> h.blockName;\par
\par
    cout << "Enter Total Hostel Fee: ";\par
    cin >> h.totalFee;\par
\par
    h.paidAmount = 0;\par
\par
    hostelList.push_back(h);\par
\par
    cout << "Hostel Student Added Successfully!" << endl;\par
\}\par
\par
// View All Hostel Students\par
void viewHostelStudents() \{\par
    if(hostelList.empty()) \{\par
        cout << "No Hostel Records Found!" << endl;\par
