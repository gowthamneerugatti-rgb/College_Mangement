using namespace std;\par
\par
// Book Structure\par
struct Book \{\par
    int bookId;\par
    string title;\par
    string author;\par
    bool isIssued;\par
\};\par
\par
// Global Book List\par
vector<Book> library;\par
\par
// Function Declarations\par
void addBook();\par
void viewBooks();\par
void searchBook();\par
void issueBook();\par
void returnBook();\par
void deleteBook();\par
void libraryMenu();\par
\par
int main() \{\par
    libraryMenu();\par
    return 0;\par
\}\par
\par
// Menu\par
void libraryMenu() \{\par
    int choice;\par
\par
    do \{\par
        cout << "\\n====== LIBRARY MANAGEMENT SYSTEM ======" << endl;\par
        cout << "1. Add Book" << endl;\par
        cout << "2. View All Books" << endl;\par
        cout << "3. Search Book" << endl;\par
        cout << "4. Issue Book" << endl;\par
        cout << "5. Return Book" << endl;\par
        cout << "6. Delete Book" << endl;\par
        cout << "7. Exit" << endl;\par
        cout << "Enter your choice: ";\par
        cin >> choice;\par
\par
        switch(choice) \{\par
            case 1: addBook(); break;\par
            case 2: viewBooks(); break;\par
            case 3: searchBook(); break;\par
            case 4: issueBook(); break;\par
            case 5: returnBook(); break;\par
            case 6: deleteBook(); break;\par
            case 7: cout << "Exiting..." << endl; break;\par
            default: cout << "Invalid Choice!" << endl;\par
        \}\par
\par
    \} while(choice != 7);\par
\}\par
\par
// Add Book\par
void addBook() \{\par
    Book b;\par
\par
    cout << "Enter Book ID: ";\par
    cin >> b.bookId;\par
\par
    cout << "Enter Book Title: ";\par
    cin >> b.title;\par
\par
    cout << "Enter Author Name: ";\par
    cin >> b.author;\par
\par
    b.isIssued = false;\par
\par
    library.push_back(b);\par
\par
    cout << "Book Added Successfully!" << endl;\par
\}\par
\par
// View All Books\par
void viewBooks() \{\par
    if(library.empty()) \{\par
        cout << "No Books Available!" << endl;\par
        return;\par
    \}\par
\par
    cout << "\\n------ BOOK LIST ------" << endl;\par
\par
    for(int i = 0; i < library.size(); i++) \{\par
        cout << "ID: " << library[i].bookId\par
             << " | Title: " << library[i].title\par
             << " | Author: " << library[i].author\par
             << " | Status: " \par
             << (library[i].isIssued ? "Issued" : "Available")\par
             << endl;\par
    \}\par
\}\par
\par
// Search Book\par
void searchBook() \{\par
    int id;\par
    cout << "Enter Book ID to Search: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < library.size(); i++) \{\par
        if(library[i].bookId == id) \{\par
            cout << "Book Found!" << endl;\par
            cout << "Title: " << library[i].title << endl;\par
            cout << "Author: " << library[i].author << endl;\par
            cout << "Status: " \par
                 << (library[i].isIssued ? "Issued" : "Available")\par
                 << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Book Not Found!" << endl;\par
\}\par
\par
// Issue Book\par
void issueBook() \{\par
    int id;\par
    cout << "Enter Book ID to Issue: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < library.size(); i++) \{\par
        if(library[i].bookId == id) \{\par
\par
            if(library[i].isIssued) \{\par
                cout << "Book Already Issued!" << endl;\par
            \} else \{\par
                library[i].isIssued = true;\par
                cout << "Book Issued Successfully!" << endl;\par
            \}\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Book Not Found!" << endl;\par
\}\par
\par
// Return Book\par
void returnBook() \{\par
    int id;\par
    cout << "Enter Book ID to Return: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < library.size(); i++) \{\par
        if(library[i].bookId == id) \{\par
\par
            if(!library[i].isIssued) \{\par
                cout << "Book is Already Available!" << endl;\par
            \} else \{\par
                library[i].isIssued = false;\par
                cout << "Book Returned Successfully!" << endl;\par
            \}\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Book Not Found!" << endl;\par
\}\par
\par
// Delete Book\par
void deleteBook() \{\par
    int id;\par
    cout << "Enter Book ID to Delete: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < library.size(); i++) \{\par
        if(library[i].bookId == id) \{\par
            library.erase(library.begin() + i);\par
            cout << "Book Deleted Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Book Not Found!" << endl;\par
\}\par
