        cout << "2. View All Courses" << endl;\par
        cout << "3. Search Course" << endl;\par
        cout << "4. Update Course" << endl;\par
        cout << "5. Delete Course" << endl;\par
        cout << "6. Exit" << endl;\par
        cout << "Enter your choice: ";\par
        cin >> choice;\par
\par
        switch(choice) \{\par
            case 1: addCourse(); break;\par
            case 2: viewCourses(); break;\par
            case 3: searchCourse(); break;\par
            case 4: updateCourse(); break;\par
            case 5: deleteCourse(); break;\par
            case 6: cout << "Exiting Program..." << endl; break;\par
            default: cout << "Invalid Choice!" << endl;\par
        \}\par
\par
    \} while(choice != 6);\par
\}\par
\par
// Add Course\par
void addCourse() \{\par
    Course c;\par
\par
    cout << "Enter Course ID: ";\par
    cin >> c.courseId;\par
\par
    cout << "Enter Course Name: ";\par
    cin >> c.courseName;\par
\par
    cout << "Enter Credits: ";\par
    cin >> c.credits;\par
\par
    cout << "Enter Instructor Name: ";\par
    cin >> c.instructor;\par
\par
    cout << "Enter Duration (months): ";\par
    cin >> c.duration;\par
\par
    courseList.push_back(c);\par
\par
    cout << "Course Added Successfully!" << endl;\par
\}\par
\par
// View Courses\par
void viewCourses() \{\par
    if(courseList.empty()) \{\par
        cout << "No Courses Found!" << endl;\par
        return;\par
    \}\par
\par
    cout << "\\n------ COURSE LIST ------" << endl;\par
\par
    for(int i = 0; i < courseList.size(); i++) \{\par
        cout << "ID: " << courseList[i].courseId\par
             << " | Name: " << courseList[i].courseName\par
             << " | Credits: " << courseList[i].credits\par
             << " | Instructor: " << courseList[i].instructor\par
             << " | Duration: " << courseList[i].duration << " months"\par
             << endl;\par
    \}\par
\}\par
\par
// Search Course\par
void searchCourse() \{\par
    int id;\par
    cout << "Enter Course ID to Search: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < courseList.size(); i++) \{\par
        if(courseList[i].courseId == id) \{\par
            cout << "Course Found!" << endl;\par
            cout << "Name: " << courseList[i].courseName << endl;\par
            cout << "Credits: " << courseList[i].credits << endl;\par
            cout << "Instructor: " << courseList[i].instructor << endl;\par
            cout << "Duration: " << courseList[i].duration << " months" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Course Not Found!" << endl;\par
\}\par
\par
// Update Course\par
void updateCourse() \{\par
    int id;\par
    cout << "Enter Course ID to Update: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < courseList.size(); i++) \{\par
        if(courseList[i].courseId == id) \{\par
            cout << "Enter New Course Name: ";\par
