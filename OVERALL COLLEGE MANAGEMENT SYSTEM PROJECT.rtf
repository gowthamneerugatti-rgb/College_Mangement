\cf1\b\f0 C++ :\par
\cf2\b0\f6\fs24 #include <iostream>\par
#include <vector>\par
#include <string>\par
\par
using namespace std;\par
\par
// Timetable Structure\par
struct Timetable \{\par
    int timetableId;\par
    string department;\par
    string course;\par
    string subject;\par
    string faculty;\par
    string day;\par
    string timeSlot;\par
    string roomNumber;\par
\};\par
\par
// Global Vector\par
vector<Timetable> timetableList;\par
\par
// Function Declarations\par
void addTimetable();\par
void viewTimetable();\par
void searchByDepartment();\par
void searchByFaculty();\par
void updateTimetable();\par
void deleteTimetable();\par
void timetableMenu();\par
\par
int main() \{\par
    timetableMenu();\par
    return 0;\par
\}\par
\par
// Menu\par
void timetableMenu() \{\par
    int choice;\par
\par
    do \{\par
        cout << "\\n====== TIMETABLE MANAGEMENT SYSTEM ======" << endl;\par
        cout << "1. Add Timetable" << endl;\par
        cout << "2. View All Timetables" << endl;\par
        cout << "3. Search by Department" << endl;\par
        cout << "4. Search by Faculty" << endl;\par
        cout << "5. Update Timetable" << endl;\par
        cout << "6. Delete Timetable" << endl;\par
        cout << "7. Exit" << endl;\par
        cout << "Enter Choice: ";\par
        cin >> choice;\par
\par
        switch(choice) \{\par
            case 1: addTimetable(); break;\par
            case 2: viewTimetable(); break;\par
            case 3: searchByDepartment(); break;\par
            case 4: searchByFaculty(); break;\par
            case 5: updateTimetable(); break;\par
            case 6: deleteTimetable(); break;\par
            case 7: cout << "Exiting..." << endl; break;\par
            default: cout << "Invalid Choice!" << endl;\par
        \}\par
\par
    \} while(choice != 7);\par
\}\par
\par
// Add Timetable\par
void addTimetable() \{\par
    Timetable t;\par
\par
    cout << "Enter Timetable ID: ";\par
    cin >> t.timetableId;\par
\par
    cout << "Enter Department: ";\par
    cin >> t.department;\par
\par
    cout << "Enter Course: ";\par
    cin >> t.course;\par
\par
    cout << "Enter Subject: ";\par
    cin >> t.subject;\par
\par
    cout << "Enter Faculty Name: ";\par
    cin >> t.faculty;\par
\par
    cout << "Enter Day: ";\par
    cin >> t.day;\par
\par
    cout << "Enter Time Slot (Ex: 10AM-11AM): ";\par
    cin >> t.timeSlot;\par
\par
    cout << "Enter Room Number: ";\par
    cin >> t.roomNumber;\par
\par
    timetableList.push_back(t);\par
\par
    cout << "Timetable Added Successfully!" << endl;\par
\}\par
\par
// View All\par
void viewTimetable() \{\par
    if(timetableList.empty()) \{\par
        cout << "No Timetable Records Found!" << endl;\par
        return;\par
    \}\par
\par
    for(auto t : timetableList) \{\par
        cout << "\\n--------------------------------" << endl;\par
        cout << "ID: " << t.timetableId << endl;\par
        cout << "Department: " << t.department << endl;\par
        cout << "Course: " << t.course << endl;\par
        cout << "Subject: " << t.subject << endl;\par
        cout << "Faculty: " << t.faculty << endl;\par
        cout << "Day: " << t.day << endl;\par
        cout << "Time: " << t.timeSlot << endl;\par
        cout << "Room: " << t.roomNumber << endl;\par
        cout << "--------------------------------" << endl;\par
    \}\par
\}\par
\par
// Search by Department\par
void searchByDepartment() \{\par
    string dept;\par
    cout << "Enter Department: ";\par
    cin >> dept;\par
\par
    for(auto t : timetableList) \{\par
        if(t.department == dept) \{\par
            cout << "\\n" << t.subject << " | "\par
                 << t.faculty << " | "\par
                 << t.day << " | "\par
                 << t.timeSlot << endl;\par
        \}\par
    \}\par
\}\par
\par
// Search by Faculty\par
void searchByFaculty() \{\par
    string fac;\par
    cout << "Enter Faculty Name: ";\par
    cin >> fac;\par
\par
    for(auto t : timetableList) \{\par
        if(t.faculty == fac) \{\par
            cout << "\\n" << t.subject << " | "\par
                 << t.department << " | "\par
                 << t.day << " | "\par
                 << t.timeSlot << endl;\par
        \}\par
    \}\par
\}\par
\par
// Update\par
void updateTimetable() \{\par
    int id;\par
    cout << "Enter Timetable ID to Update: ";\par
    cin >> id;\par
\par
    for(auto &t : timetableList) \{\par
        if(t.timetableId == id) \{\par
\par
            cout << "Enter New Subject: ";\par
            cin >> t.subject;\par
\par
            cout << "Enter New Faculty: ";\par
            cin >> t.faculty;\par
\par
            cout << "Enter New Time Slot: ";\par
            cin >> t.timeSlot;\par
\par
            cout << "Updated Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Delete\par
void deleteTimetable() \{\par
    int id;\par
    cout << "Enter Timetable ID to Delete: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < timetableList.size(); i++) \{\par
        if(timetableList[i].timetableId == id) \{\par
            timetableList.erase(timetableList.begin() + i);\par
            cout << "Deleted Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
