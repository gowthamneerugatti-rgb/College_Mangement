    cout << "Student ID: " << h.studentId << endl;\par
    cout << "Student Name: " << h.studentName << endl;\par
    cout << "Room Number: " << h.roomNumber << endl;\par
    cout << "Block: " << h.blockName << endl;\par
    cout << "------------------------------" << endl;\par
    cout << "Total Fee: " << h.totalFee << endl;\par
    cout << "Paid Amount: " << h.paidAmount << endl;\par
    cout << "Due Amount: " << due << endl;\par
