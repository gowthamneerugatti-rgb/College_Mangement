        cout << "Enter your choice: ";\par
        cin >> choice;\par
\par
        switch(choice) \{\par
            case 1: addExam(); break;\par
            case 2: viewExams(); break;\par
            case 3: searchResult(); break;\par
            case 4: updateMarks(); break;\par
            case 5: deleteRecord(); break;\par
            case 6: calculateResult(); break;\par
            case 7: cout << "Exiting Program..." << endl; break;\par
            default: cout << "Invalid Choice!" << endl;\par
        \}\par
\par
    \} while(choice != 7);\par
