// Menu\par
void attendanceMenu() \{\par
    int choice;\par
\par
    do \{\par
        cout << "\\n====== ATTENDANCE MANAGEMENT SYSTEM ======" << endl;\par
        cout << "1. Mark Attendance" << endl;\par
        cout << "2. View All Records" << endl;\par
        cout << "3. Search Attendance" << endl;\par
        cout << "4. Update Attendance" << endl;\par
        cout << "5. Delete Record" << endl;\par
        cout << "6. Calculate Attendance Percentage" << endl;\par
        cout << "7. Exit" << endl;\par
        cout << "Enter your choice: ";\par
        cin >> choice;\par
\par
        switch(choice) \{\par
            case 1: markAttendance(); break;\par
            case 2: viewAttendance(); break;\par
            case 3: searchAttendance(); break;\par
            case 4: updateAttendance(); break;\par
            case 5: deleteAttendance(); break;\par
            case 6: calculatePercentage(); break;\par
            case 7: cout << "Exiting Program..." << endl; break;\par
            default: cout << "Invalid Choice!" << endl;\par
        \}\par
\par
    \} while(choice != 7);\par
\}\par
\par
// Mark Attendance\par
void markAttendance() \{\par
    Attendance a;\par
\par
    cout << "Enter Student ID: ";\par
    cin >> a.studentId;\par
\par
    cout << "Enter Student Name: ";\par
    cin >> a.studentName;\par
\par
    cout << "Enter Total Classes Conducted: ";\par
    cin >> a.totalClasses;\par
\par
    cout << "Enter Classes Attended: ";\par
    cin >> a.classesAttended;\par
\par
    attendanceList.push_back(a);\par
\par
    cout << "Attendance Recorded Successfully!" << endl;\par
\}\par
\par
// View All Attendance\par
void viewAttendance() \{\par
    if(attendanceList.empty()) \{\par
        cout << "No Attendance Records Found!" << endl;\par
        return;\par
    \}\par
\par
    cout << "\\n------ ATTENDANCE RECORDS ------" << endl;\par
\par
    for(int i = 0; i < attendanceList.size(); i++) \{\par
        cout << "Student ID: " << attendanceList[i].studentId\par
             << " | Name: " << attendanceList[i].studentName\par
             << " | Total Classes: " << attendanceList[i].totalClasses\par
             << " | Attended: " << attendanceList[i].classesAttended\par
             << endl;\par
    \}\par
\}\par
\par
// Search Attendance\par
void searchAttendance() \{\par
    int id;\par
    cout << "Enter Student ID to Search: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < attendanceList.size(); i++) \{\par
        if(attendanceList[i].studentId == id) \{\par
            cout << "Record Found!" << endl;\par
            cout << "Name: " << attendanceList[i].studentName << endl;\par
            cout << "Total Classes: " << attendanceList[i].totalClasses << endl;\par
            cout << "Classes Attended: " << attendanceList[i].classesAttended << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Update Attendance\par
void updateAttendance() \{\par
    int id;\par
    cout << "Enter Student ID to Update: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < attendanceList.size(); i++) \{\par
        if(attendanceList[i].studentId == id) \{\par
            cout << "Enter New Total Classes: ";\par
            cin >> attendanceList[i].totalClasses;\par
\par
            cout << "Enter New Classes Attended: ";\par
            cin >> attendanceList[i].classesAttended;\par
\par
            cout << "Attendance Updated Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Delete Attendance\par
void deleteAttendance() \{\par
    int id;\par
    cout << "Enter Student ID to Delete Record: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < attendanceList.size(); i++) \{\par
        if(attendanceList[i].studentId == id) \{\par
            attendanceList.erase(attendanceList.begin() + i);\par
            cout << "Record Deleted Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Calculate Attendance Percentage\par
void calculatePercentage() \{\par
    int id;\par
    cout << "Enter Student ID to Calculate Percentage: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < attendanceList.size(); i++) \{\par
        if(attendanceList[i].studentId == id) \{\par
\par
            if(attendanceList[i].totalClasses == 0) \{\par
                cout << "Total Classes Cannot Be Zero!" << endl;\par
                return;\par
            \}\par
\par
            float percentage = (attendanceList[i].classesAttended * 100.0) / attendanceList[i].totalClasses;\par
\par
            cout << "Attendance Percentage: " << percentage << "%" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
