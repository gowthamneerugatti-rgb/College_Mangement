void payHostelFee() \{\par
    int id;\par
    float amount;\par
\par
    cout << "Enter Student ID: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < hostelList.size(); i++) \{\par
        if(hostelList[i].studentId == id) \{\par
\par
            cout << "Enter Amount to Pay: ";\par
            cin >> amount;\par
\par
            hostelList[i].paidAmount += amount;\par
\par
            if(hostelList[i].paidAmount > hostelList[i].totalFee)\par
                hostelList[i].paidAmount = hostelList[i].totalFee;\par
\par
            cout << "Payment Successful!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
