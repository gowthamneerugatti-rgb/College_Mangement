<script>\par
function assignHOD(rowId) \{\par
    const input = document.getElementById(`input-$\{rowId\}`);\par
    const hodCell = document.getElementById(`hod-$\{rowId\}`);\par
    const newHOD = input.value.trim();\par
\par
    if(newHOD) \{\par
        hodCell.innerText = newHOD;\par
        alert(`HOD for $\{hodCell.parentElement.cells[1].innerText\} assigned to $\{newHOD\}`);\par
        input.value = '';\par
    \} else \{\par
        alert('Please enter HOD name!');\par
    \}\par
\}\par
</script>\par
