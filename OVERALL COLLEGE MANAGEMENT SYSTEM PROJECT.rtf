\cf2\b0\f6\fs24 #include <iostream>\par
#include <vector>\par
#include <string>\par
#include <iomanip>\par
\par
using namespace std;\par
\par
// Fee Structure\par
struct Fee \{\par
    int studentId;\par
    string studentName;\par
    float totalFee;\par
    float paidAmount;\par
\};\par
\par
// Global Fee List\par
vector<Fee> feeList;\par
\par
// Function Declarations\par
void addFee();\par
void viewFees();\par
void searchFee();\par
void payFee();\par
void deleteFee();\par
void feeMenu();\par
void generateReceipt(Fee f);\par
\par
int main() \{\par
    feeMenu();\par
    return 0;\par
\}\par
\par
// Menu\par
void feeMenu() \{\par
    int choice;\par
\par
    do \{\par
        cout << "\\n====== FEE MANAGEMENT SYSTEM ======" << endl;\par
        cout << "1. Add Fee Record" << endl;\par
        cout << "2. View All Records" << endl;\par
        cout << "3. Search Student Fee" << endl;\par
        cout << "4. Pay Fee" << endl;\par
        cout << "5. Delete Record" << endl;\par
        cout << "6. Exit" << endl;\par
        cout << "Enter your choice: ";\par
        cin >> choice;\par
\par
        switch(choice) \{\par
            case 1: addFee(); break;\par
            case 2: viewFees(); break;\par
            case 3: searchFee(); break;\par
            case 4: payFee(); break;\par
            case 5: deleteFee(); break;\par
            case 6: cout << "Exiting..." << endl; break;\par
            default: cout << "Invalid Choice!" << endl;\par
        \}\par
\par
    \} while(choice != 6);\par
\}\par
\par
// Add Fee Record\par
void addFee() \{\par
    Fee f;\par
\par
    cout << "Enter Student ID: ";\par
    cin >> f.studentId;\par
\par
    cout << "Enter Student Name: ";\par
    cin >> f.studentName;\par
\par
    cout << "Enter Total Fee: ";\par
    cin >> f.totalFee;\par
\par
    f.paidAmount = 0;  // initially zero\par
\par
    feeList.push_back(f);\par
\par
    cout << "Fee Record Added Successfully!" << endl;\par
\}\par
\par
// View All Fees\par
void viewFees() \{\par
    if(feeList.empty()) \{\par
        cout << "No Fee Records Found!" << endl;\par
        return;\par
    \}\par
\par
    for(int i = 0; i < feeList.size(); i++) \{\par
        generateReceipt(feeList[i]);\par
    \}\par
\}\par
\par
// Search Fee\par
void searchFee() \{\par
    int id;\par
    cout << "Enter Student ID to Search: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < feeList.size(); i++) \{\par
        if(feeList[i].studentId == id) \{\par
            generateReceipt(feeList[i]);\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Pay Fee\par
void payFee() \{\par
    int id;\par
    float amount;\par
\par
    cout << "Enter Student ID: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < feeList.size(); i++) \{\par
        if(feeList[i].studentId == id) \{\par
\par
            cout << "Enter Amount to Pay: ";\par
            cin >> amount;\par
\par
            feeList[i].paidAmount += amount;\par
\par
            if(feeList[i].paidAmount > feeList[i].totalFee)\par
                feeList[i].paidAmount = feeList[i].totalFee;\par
\par
            cout << "Payment Successful!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Delete Fee Record\par
void deleteFee() \{\par
    int id;\par
    cout << "Enter Student ID to Delete: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < feeList.size(); i++) \{\par
        if(feeList[i].studentId == id) \{\par
            feeList.erase(feeList.begin() + i);\par
            cout << "Record Deleted Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
\}\par
\par
// Generate Receipt\par
void generateReceipt(Fee f) \{\par
\par
    float due = f.totalFee - f.paidAmount;\par
\par
    cout << "\\n==============================" << endl;\par
    cout << "          FEE RECEIPT         " << endl;\par
    cout << "==============================" << endl;\par
    cout << "Student ID: " << f.studentId << endl;\par
    cout << "Student Name: " << f.studentName << endl;\par
    cout << "------------------------------" << endl;\par
    cout << "Total Fee: " << f.totalFee << endl;\par
    cout << "Paid Amount: " << f.paidAmount << endl;\par
    cout << "Due Amount: " << due << endl;\par
\par
    if(due == 0)\par
        cout << "Status: PAID" << endl;\par
    else\par
        cout << "Status: PENDING" << endl;\par
\par
    cout << "==============================" << endl;\par
\}\par
