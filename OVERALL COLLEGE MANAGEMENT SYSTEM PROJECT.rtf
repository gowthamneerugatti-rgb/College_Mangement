\par
            cout << "Enter New Instructor: ";\par
            cin >> courseList[i].instructor;\par
\par
            cout << "Enter New Duration (months): ";\par
            cin >> courseList[i].duration;\par
\par
            cout << "Course Updated Successfully!" << endl;\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Course Not Found!" << endl;\par
\}\par
\par
// Delete Course\par
void deleteCourse() \{\par
    int id;\par
    cout << "Enter Course ID to Delete: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < courseList.size(); i++) \{\par
