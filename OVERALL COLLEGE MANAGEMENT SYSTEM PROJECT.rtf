// Add Exam Record\par
void addExam() \{\par
    Exam e;\par
\par
    cout << "Enter Student ID: ";\par
    cin >> e.studentId;\par
\par
    cout << "Enter Student Name: ";\par
    cin >> e.studentName;\par
\par
    cout << "Enter Marks for Subject 1: ";\par
    cin >> e.subject1;\par
\par
    cout << "Enter Marks for Subject 2: ";\par
    cin >> e.subject2;\par
\par
    cout << "Enter Marks for Subject 3: ";\par
    cin >> e.subject3;\par
\par
    examList.push_back(e);\par
\par
    cout << "Exam Record Added Successfully!" << endl;\par
