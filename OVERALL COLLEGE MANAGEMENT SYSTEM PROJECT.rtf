// Search Hostel Student\par
void searchHostelStudent() \{\par
    int id;\par
    cout << "Enter Student ID to Search: ";\par
    cin >> id;\par
\par
    for(int i = 0; i < hostelList.size(); i++) \{\par
        if(hostelList[i].studentId == id) \{\par
            generateHostelReceipt(hostelList[i]);\par
            return;\par
        \}\par
    \}\par
\par
    cout << "Record Not Found!" << endl;\par
